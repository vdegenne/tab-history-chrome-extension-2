{
	"name": "tab-history-chrome-extension-2",
	"version": "0.1.0",
	"description": "",
	"type": "module",
	"scripts": {
		"build": "wireit"
	},
	"wireit": {
		"build": {
			"dependencies": [
				"build:ts",
				"build:rollup",
				"pwa-assets",
				"build:options",
				"build:popup",
				"build:offscreen",
				"build:sidepanel"
			]
		},
		"build:ts": {
			"command": "tsc",
			"clean": "if-file-deleted",
			"files": [
				"./tsconfig.json",
				"./src/**/*",
				"!./src/UI/"
			],
			"output": [
				"./lib/"
			]
		},
		"build:rollup": {
			"command": "rollup -c",
			"dependencies": [
				"build:ts"
			],
			"files": [
				"./rollup.config.js"
			],
			"output": [
				"./content.js",
				"./background.js"
			]
		},
		"build:options": {
			"command": "vite build documents/options --config ./vite.config.js",
			"files": [
				"./vite.config.js",
				"./src/**/*",
				"./documents/options/index.html"
			],
			"output": [
				"./documents/options/dist/"
			]
		},
		"build:popup": {
			"command": "vite build documents/popup --config ./vite.config.js",
			"files": [
				"./vite.config.js",
				"./src/**/*",
				"./documents/popup/index.html"
			],
			"output": [
				"./documents/popup/dist/"
			]
		},
		"build:offscreen": {
			"command": "vite build documents/offscreen --config ./vite.config.js",
			"files": [
				"./vite.config.js",
				"./src/**/*",
				"./documents/offscreen/index.html"
			],
			"output": [
				"./documents/offscreen/dist/"
			]
		},
		"build:sidepanel": {
			"command": "vite build documents/sidepanel --config ./vite.config.js",
			"files": [
				"./vite.config.js",
				"./src/**/*",
				"./documents/sidepanel/index.html"
			],
			"output": [
				"./documents/sidepanel/dist/"
			]
		},
		"pwa-assets": {
			"command": "pwa-assets-generator --preset minimal-2023 --html.preset 2025 ./assets/img/logo.svg && node ./scripts/generate-128-icon.js",
			"files": [
				"./scripts/generate-128-icon.js",
				"./assets/img/logo.svg"
			],
			"output": [
				"./assets/img/pwa-64x64.png",
				"./assets/img/pwa-192x192.png",
				"./assets/img/pwa-512x512.png",
				"./assets/img/maskable-icon-512x512.png",
				"./assets/img/apple-touch-icon-180x180.png",
				"./assets/img/favicon.ico",
				"./assets/img/chrome-store-128x128.png"
			]
		}
	},
	"devDependencies": {
		"@material/web": "^2.4.1",
		"@snar/lit": "^1.8.1",
		"@tailwindcss/postcss": "^4.2.4",
		"@types/chrome": "^0.1.40",
		"@vdegenne/chrome-extension": "^0.1.21",
		"@vdegenne/debouncer": "^1.0.12",
		"@vdegenne/forms": "^0.1.72",
		"@vdegenne/material-color-helpers": "^1.11.7",
		"@vdegenne/rollup": "^0.1.14",
		"@vdegenne/rollup-plugin-minify-html": "^1.0.6",
		"@vdegenne/vite-plugin-css-modules": "^0.1.12",
		"@vite-pwa/assets-generator": "^1.0.2",
		"custom-element-decorator": "^0.6.0",
		"lit": "^3.3.2",
		"lit-with-styles": "^2.1.3",
		"material-shell": "^1.3.10",
		"rollup-plugin-material-all": "^1.2.2",
		"rollup-plugin-minify-template-literals": "^1.1.7",
		"sharp": "^0.34.5",
		"snar-save-to-local-storage": "^1.0.1",
		"typescript": "^6.0.3",
		"vite": "^8.0.10",
		"vite-plugin-mdicon2svg": "^0.2.3",
		"wireit": "^0.14.12"
	}
}
